# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
AGENT_API_KEY=change-me-in-production

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Cost Guard
MONTHLY_BUDGET_USD=10.0

# Optional: OpenAI
# OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-3.5-turbo
